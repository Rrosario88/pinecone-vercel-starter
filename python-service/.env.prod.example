# Production Environment Configuration
# Copy this file to .env.prod and update with your production values

# OpenAI Configuration
OPENAI_API_KEY=your_production_openai_api_key_here

# Pinecone Configuration
PINECONE_API_KEY=your_production_pinecone_api_key_here
PINECONE_INDEX=your_production_pinecone_index_name
PINECONE_ENVIRONMENT=us-east-1

# Service Configuration
PORT=8000
NODE_ENV=production
LOG_LEVEL=INFO

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://backend:8000
AUTOGEN_SERVICE_URL=http://backend:8000

# Security Configuration
# Add any additional security-related environment variables here
# CORS_ORIGINS=https://yourdomain.com
# API_SECRET_KEY=your_production_secret_key