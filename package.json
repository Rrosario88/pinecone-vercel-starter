{
  "name": "vercel-pinecone-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:show": "playwright show-report",
    "autogen:dev": "cd python-service && pip install -r requirements.txt && uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "autogen:test": "cd python-service && python test_autogen.py",
    "docker:up": "docker-compose up -d --build",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f autogen-service",
    "dev:full": "docker-compose up --build"
  },
  "dependencies": {
    "@ai-sdk/openai": "^0.0.60",
    "@pinecone-database/doc-splitter": "^0.0.1",
    "@pinecone-database/pinecone": "^6.1.1",
    "@tailwindcss/typography": "^0.5.16",
    "@types/multer": "^2.0.0",
    "ai": "^3.3.39",
    "cheerio": "^1.0.0",
    "eslint": "^8.0.0",
    "framer-motion": "^12.23.6",
    "fs-extra": "^11.3.0",
    "lucide-react": "^0.525.0",
    "md5": "^2.3.0",
    "multer": "^2.0.1",
    "next": "^15.1.0",
    "node-html-markdown": "^1.3.0",
    "openai-edge": "^1.2.2",
    "pdf-parse-fork": "^1.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.3.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.1",
    "sswr": "^2.1.0",
    "svelte": "^4.2.19",
    "tailwindcss": "3.4.11",
    "typescript": "^5.8.3",
    "unified": "^11.0.5",
    "vue": "^3.5.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.1",
    "@types/fs-extra": "^11.0.4",
    "@types/md5": "^2.3.5",
    "@types/node": "22.5.5",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint-config-next": "^15.1.0"
  }
}
